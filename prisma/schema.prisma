generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(uuid())
  username          String               @unique
  password          String
  securityCode      String               @default("")
  role              String               @default("USER")
  status            String               @default("ACTIVE")
  balance           Float                @default(0.00)
  commissionBalance Float                @default(0.00)
  inviteCode        String               @unique
  parentId          String?
  createdAt         DateTime             @default(now())
  orders            Order[]
  transactions      TransactionHistory[]
  nodes             NodeInstance[]
}

model Product {
  id          String             @id @default(uuid())
  title       String
  description String
  image       String
  originalPrice Float             @default(0)
  price       Float
  agentPrice  Float
  status      Boolean            @default(true)
  category    String             @default("LIVE")
  createdAt   DateTime           @default(now())
  configs     AgentPriceConfig[]
  orders      Order[]
  nodes       NodeInstance[]
}

model AgentPriceConfig {
  id          String  @id @default(uuid())
  agentId     String
  subAgentId  String
  productId   String
  customPrice Float
  product     Product @relation(fields: [productId], references: [id])
}

model Order {
  id            String               @id @default(uuid())
  orderNo       String               @unique
  userId        String
  productId     String
  amount        Float
  status        String               @default("PENDING")
  paymentMethod String
  createdAt     DateTime             @default(now())
  user          User                 @relation(fields: [userId], references: [id])
  product       Product              @relation(fields: [productId], references: [id])
  transactions  TransactionHistory[]
  node          NodeInstance?
}

model NodeInstance {
  id           String   @id @default(uuid())
  productId    String
  host         String
  port         Int
  protocol     String   @default("trojan")
  password     String
  remark       String   @default("")
  status       String   @default("AVAILABLE")
  orderId      String?  @unique
  userId       String?
  expireAt     DateTime?
  trafficLimit Float    @default(0)
  trafficUsed  Float    @default(0)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id])
  order        Order?   @relation(fields: [orderId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model TransactionHistory {
  id         String   @id @default(uuid())
  userId     String
  orderId    String?
  type       String
  walletType String
  amount     Float
  remark     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])
}

model PaymentConfig {
  id         String   @id @default(uuid())
  platform   String
  merchantId String
  apiKey     String
  secretKey  String
  notifyUrl  String
  status     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
