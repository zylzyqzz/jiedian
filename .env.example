# NodeHub Platform · 环境变量配置
# 复制此文件为 .env 并修改

# ============================================
# 🔐 JWT 签名密钥（必填）
# ============================================
# 生产环境务必更换为随机字符串（至少 32 位）
# 示例生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-change-me-in-production

# ============================================
# 📦 数据库（必填 — PostgreSQL）
# ============================================
# 推荐 Supabase（免费 500MB）或 Neon（免费 500MB）
# 获取地址：https://supabase.com 或 https://neon.tech
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxx.supabase.co:5432/postgres

# ============================================
# 🌐 应用端口（可选）
# ============================================
# PORT=3000

# ============================================
# 💳 支付配置（可选）
# ============================================
# 支付配置请在管理后台「支付配置」面板中添加
# 支持易支付标准接口（MD5 签名）
